# Copy to `.env` locally. On Vercel, set these in Project Settings → Environment Variables.

# Same Postgres/Neon DATABASE_URL as the main Player Tracker app (intake writes to the same DB).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require

# Must match active season labeling in the main app (e.g. 2026-2027).
DEFAULT_SEASON_LABEL=2026-2027

# Public URL of the main coach/admin app (used for links like “Login to app”).
MAIN_APP_URL=https://your-main-app.vercel.app
