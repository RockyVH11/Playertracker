// Player tracker — production targets Neon + Vercel (PostgreSQL only)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COACH
}

enum Gender {
  BOYS
  GIRLS
}

enum EvaluationLevel {
  RL
  N1
  N2
  GRASSROOTS
  NOT_EVALUATED
}

enum PlayerStatus {
  AVAILABLE
  INVITED
  COMMITTED
  NOT_INTERESTED
  ARCHIVED
}

enum PlayerPosition {
  GK
  DEFENDER
  MIDFIELDER
  FORWARD
  UTILITY
  UNKNOWN
}

enum PlayerSource {
  COACH_ENTERED
  PARENT_INTEREST_FORM
  OPEN_SESSION
  EXISTING_PLAYER
  COACH_REFERRAL
  OTHER
}

enum PlacementPriority {
  HIGH
  MEDIUM
  LOW
  WATCH_LIST
}

/// App-level staff role for permissions (distinct from CSV display `staffRoleLabel`).
enum StaffRole {
  DIRECTOR
  COACH
  MANAGER
}

enum ProspectType {
  PLAYER
  TEAM
  COACH
}

enum ProspectStatus {
  NEW
  ASSIGNED
  CONTACTED
  IN_PROGRESS
  CONVERTED
  CLOSED
}

enum DayOfWeek {
  SUN
  MON
  TUE
  WED
  THU
  FRI
  SAT
}

enum FieldRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum EquipmentReservationStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

/// Future real accounts; optional fields for MVP
model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  displayName String
  role        Role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evaluationAuthoredPlayers Player[] @relation("PlayerEvaluationAuthorUser")
  createdPlayers            Player[] @relation("PlayerCreatedByUser")
  updatedPlayers            Player[] @relation("PlayerUpdatedByUser")
}

model Coach {
  id                String    @id @default(cuid())
  firstName         String
  lastName          String
  email             String?   @unique
  phone             String?
  /// CSV / picker display text; prefer `staffRole` for authorization.
  staffRoleLabel    String?
  staffRole         StaffRole @default(COACH)
  primaryAreaLabel  String?
  primaryLocationId String?
  primaryLocation   Location? @relation("CoachPrimaryLocation", fields: [primaryLocationId], references: [id], onDelete: SetNull)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  teams                     Team[]
  createdPlayers            Player[] @relation("PlayerCreatedByCoach")
  evaluationAuthoredPlayers Player[] @relation("PlayerEvaluationAuthorCoach")

  prospectsAssigned   Prospect[] @relation("ProspectAssignedToCoach")
  prospectsSubmitted  Prospect[] @relation("ProspectSubmittedByCoach")

  fieldRequestsSubmitted    FieldRequest[]          @relation("FieldRequestSubmittedByCoach")
  equipmentReservationsMade EquipmentReservation[]  @relation("EquipmentReservedByCoach")
}

/// Training complex within a Location (e.g. "Boneyard" at Midland).
model Complex {
  id        String   @id @default(cuid())
  locationId String
  location  Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  name      String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields              Field[]
  availabilityWindows ComplexAvailability[]
  fieldBlackouts      FieldBlackout[]

  @@index([locationId, isActive])
}

/// Single pitch / grid cell within a Complex (e.g. "1N", "3S").
model Field {
  id        String   @id @default(cuid())
  complexId String
  complex   Complex  @relation(fields: [complexId], references: [id], onDelete: Restrict)
  name      String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fieldRequestsPreferred FieldRequest[]    @relation("FieldRequestPreferredField")
  fieldAssignments       FieldAssignment[]
  fieldBlackouts         FieldBlackout[]
  availabilityWindows    FieldAvailability[]

  @@index([complexId, isActive])
}

/// Optional field-level overrides that must remain within ComplexAvailability windows.
model FieldAvailability {
  id          String    @id @default(cuid())
  fieldId     String
  field       Field     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  dayOfWeek   DayOfWeek
  /// Local clock "HH:mm" (24h) per app convention — same TZ as schedules.
  startTime   String
  endTime     String
  slotMinutes Int       @default(30)
  isActive    Boolean   @default(true)

  @@index([fieldId, dayOfWeek, isActive])
}

/// Published open hours used to drive slot grids (Phase B consumes this).
model ComplexAvailability {
  id          String    @id @default(cuid())
  complexId   String
  complex     Complex   @relation(fields: [complexId], references: [id], onDelete: Cascade)
  dayOfWeek   DayOfWeek
  /// Local clock "HH:mm" (24h) per app convention — same TZ as schedules.
  startTime   String
  endTime     String
  slotMinutes Int       @default(30)
  isActive    Boolean   @default(true)

  @@index([complexId, dayOfWeek, isActive])
}

model FieldRequest {
  id                              String             @id @default(cuid())
  seasonLabel                     String
  teamId                          String
  team                            Team               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  requestedByCoachId              String
  requestedByCoach                Coach              @relation("FieldRequestSubmittedByCoach", fields: [requestedByCoachId], references: [id], onDelete: Restrict)
  preferredDayOfWeek              DayOfWeek
  preferredStartTime              String
  preferredSessionLengthMinutes   Int
  preferredFieldId                String?
  preferredField                  Field?             @relation("FieldRequestPreferredField", fields: [preferredFieldId], references: [id], onDelete: SetNull)
  recurrenceRequested             Boolean            @default(false)
  recurrenceEndDate               DateTime?          @db.Date
  duplicateToOtherDays            DayOfWeek[]        @default([])
  notes                           String?
  status                          FieldRequestStatus @default(PENDING)
  directorNotes                   String?
  createdAt                       DateTime           @default(now())
  updatedAt                       DateTime           @updatedAt

  resultingAssignments FieldAssignment[] @relation("AssignmentFromFieldRequest")

  @@index([status, seasonLabel])
  @@index([teamId])
  @@index([requestedByCoachId])
}

model FieldAssignment {
  id                 String       @id @default(cuid())
  seasonLabel        String
  teamId             String
  team               Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  fieldId            String
  field              Field        @relation(fields: [fieldId], references: [id], onDelete: Restrict)
  assignmentDate     DateTime     @db.Date
  /// Local clock "HH:mm" (24h)
  startTime          String
  endTime            String
  recurrenceGroupId  String?
  sourceRequestId    String?
  sourceRequest      FieldRequest? @relation("AssignmentFromFieldRequest", fields: [sourceRequestId], references: [id], onDelete: SetNull)
  /// Director notes ("south half only", lights off time, …).
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  linkedEquipmentReservation EquipmentReservation[] @relation("EquipmentLinkedFieldAssignment")

  @@index([fieldId, assignmentDate])
  @@index([teamId, assignmentDate])
  @@index([recurrenceGroupId])
  @@index([sourceRequestId])
}

model FieldBlackout {
  id           String    @id @default(cuid())
  complexId    String
  complex      Complex   @relation(fields: [complexId], references: [id], onDelete: Cascade)
  fieldId      String?
  field        Field?    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  blackoutDate DateTime  @db.Date
  startTime    String?
  endTime      String?
  reason       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([complexId, blackoutDate])
  @@index([fieldId, blackoutDate])
}

model EquipmentItem {
  id           String    @id @default(cuid())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  name         String
  description  String?
  /// How many identical units can be out at the same time (e.g. 4 small goals).
  concurrentCapacity Int   @default(1)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  reservations EquipmentReservation[]

  @@index([locationId, isActive])
}

model EquipmentReservation {
  id                      String                       @id @default(cuid())
  equipmentItemId         String
  equipmentItem           EquipmentItem                @relation(fields: [equipmentItemId], references: [id], onDelete: Restrict)
  teamId                  String
  team                    Team                         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  reservedByCoachId       String
  reservedByCoach         Coach                        @relation("EquipmentReservedByCoach", fields: [reservedByCoachId], references: [id], onDelete: Restrict)
  reservationDate         DateTime                     @db.Date
  startTime               String
  endTime                 String
  /// Units checked out (goals, pole sets, …); counts toward concurrentCapacity on the item.
  quantity                Int                          @default(1)
  linkedFieldAssignmentId String?
  linkedFieldAssignment   FieldAssignment?             @relation("EquipmentLinkedFieldAssignment", fields: [linkedFieldAssignmentId], references: [id], onDelete: SetNull)
  status                  EquipmentReservationStatus @default(ACTIVE)
  notes                   String?
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt

  @@index([equipmentItemId, reservationDate, status])
  @@index([teamId, reservationDate])
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams          Team[]
  players        Player[]
  primaryCoaches Coach[]         @relation("CoachPrimaryLocation")
  prospects      Prospect[]
  complexes      Complex[]
  equipmentItems EquipmentItem[]
}

model League {
  id                   String   @id @default(cuid())
  name                 String   @unique
  allowedGender        Gender?
  conference           String?
  ageGroup             String?
  hierarchy            Int?
  capacity             Int?
  format               String?
  notes                String?
  adminOverrideAllowed Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  teams           Team[]
  playerInterests Player[] @relation("PlayerLeagueInterest")
}

model Team {
  id                        String   @id @default(cuid())
  seasonLabel               String
  teamName                  String
  locationId                String
  location                  Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  gender                    Gender
  ageGroup                  String
  coachId                   String
  coach                     Coach    @relation(fields: [coachId], references: [id], onDelete: Restrict)
  leagueId                  String?
  league                    League?  @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  openSession               Boolean  @default(true)
  committedPlayerCount      Int      @default(0)
  coachEstimatedPlayerCount Int      @default(0)
  returningPlayerCount      Int      @default(0)
  neededPlayerCount         Int      @default(0)
  neededGoalkeepers         Int      @default(0)
  neededDefenders           Int      @default(0)
  neededMidfielders         Int      @default(0)
  neededForwards            Int      @default(0)
  neededUtility             Int      @default(0)
  recruitingNeeds           String?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  players Player[]

  fieldRequests           FieldRequest[]
  fieldAssignments        FieldAssignment[]
  equipmentReservations   EquipmentReservation[]

  @@index([seasonLabel, locationId, gender, ageGroup, leagueId, openSession])
}

model AgeGroupRule {
  id          String   @id @default(cuid())
  seasonLabel String
  gender      Gender
  ageGroup    String
  dobStart    DateTime @db.Date
  dobEnd      DateTime @db.Date
  sortOrder   Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([seasonLabel, gender, ageGroup])
  @@index([seasonLabel, gender, isActive])
  @@index([gender, dobStart, dobEnd, isActive])
}

model Player {
  id          String   @id @default(cuid())
  seasonLabel String
  firstName   String
  lastName    String
  dob         DateTime @db.Date
  gender      Gender

  derivedAgeGroup  String
  overrideAgeGroup String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Restrict)

  assignedTeamId String?
  assignedTeam   Team?   @relation(fields: [assignedTeamId], references: [id], onDelete: SetNull)

  leagueInterestId String?
  leagueInterest   League? @relation("PlayerLeagueInterest", fields: [leagueInterestId], references: [id], onDelete: SetNull)

  playerStatus             PlayerStatus      @default(AVAILABLE)
  willingToPlayUp          Boolean           @default(false)
  primaryPosition          PlayerPosition    @default(UNKNOWN)
  secondaryPosition        PlayerPosition?
  playerSource             PlayerSource      @default(COACH_ENTERED)
  placementPriority        PlacementPriority @default(MEDIUM)
  externalInterestFormId   String?
  sourceSubmittedAt        DateTime?
  importedFromInterestForm Boolean           @default(false)

  evaluationLevel         EvaluationLevel @default(NOT_EVALUATED)
  evaluationNotes         String?
  evaluationAuthorCoachId String?
  evaluationAuthorCoach   Coach?          @relation("PlayerEvaluationAuthorCoach", fields: [evaluationAuthorCoachId], references: [id], onDelete: SetNull)
  evaluationAuthorUserId  String?
  evaluationAuthorUser    User?           @relation("PlayerEvaluationAuthorUser", fields: [evaluationAuthorUserId], references: [id], onDelete: SetNull)
  evaluationUpdatedAt     DateTime?

  createdByCoachId String?
  createdByCoach   Coach?  @relation("PlayerCreatedByCoach", fields: [createdByCoachId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdByUser   User?   @relation("PlayerCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  updatedByUser   User?   @relation("PlayerUpdatedByUser", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  contact   PlayerContact?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([gender, seasonLabel, derivedAgeGroup, overrideAgeGroup, locationId, playerStatus, evaluationLevel, assignedTeamId, primaryPosition])
  @@index([seasonLabel, firstName, lastName, dob, gender])
}

model PlayerContact {
  playerId      String   @id
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  guardianName  String?
  guardianPhone String?
  guardianEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Prospect {
  id        String       @id @default(cuid())
  prospectType ProspectType
  /// Full player/coach name, or team name for TEAM prospects.
  prospectName           String
  contactFirstName       String?
  contactLastName        String?
  contactPhone           String?
  contactEmail           String?
  locationId             String?
  location               Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationUnknown        Boolean   @default(false)
  assignedToCoachId      String?
  assignedToCoach        Coach?    @relation("ProspectAssignedToCoach", fields: [assignedToCoachId], references: [id], onDelete: SetNull)
  submittedByCoachId     String
  submittedByCoach       Coach     @relation("ProspectSubmittedByCoach", fields: [submittedByCoachId], references: [id], onDelete: Restrict)
  notes                  String?
  status                 ProspectStatus @default(NEW)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  assignedAt             DateTime?
  convertedAt            DateTime?
  closedAt               DateTime?

  @@index([status, prospectType])
  @@index([locationId])
  @@index([assignedToCoachId])
  @@index([submittedByCoachId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorRole   Role
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt])
}
