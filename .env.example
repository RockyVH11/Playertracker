# PostgreSQL (Neon in production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Shared login (MVP)
COACH_SHARED_PASSWORD="change-me-coach"
SUPER_ADMIN_PASSWORD="change-me-admin"

# Session HMAC (min 32 chars in production)
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Default season for new records (e.g. 2026-2027)
DEFAULT_SEASON_LABEL="2026-2027"
